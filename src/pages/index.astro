---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import '../styles/global.css';

const projects = await getCollection('projects');
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Maria Warnes</title>
	</head>
	<body class="bg-taupe-100">
    <header>
    <div class="max-w-360 p-6 md:p-10 flex items-center justify-between flex-row">
      <h1 >Maria Warnes</h1>
      <a class="text-sm font-light" href="mailto:maria.l.warnes@gmail.com">maria.l.warnes@gmail.com</a>
      </div>
    </header>
    <div class="mx-auto max-w-360 p-6 md:p-10">
      <section class="min-h-100 md:min-h-140 flex justify-center flex-col">
        <h2 class="max-w-xl text-4xl md:text-6xl">
        Front end developer with a design background.
        </h2>
        <div class="w-12 h-0.5 my-8 border-top bg-taupe-400"></div>
        <p class="">I build clean, accessible and user-focused interfaces with attention to detail.</p>
      </section>
      <section class="">
        <h3 class="text-2xl md:text-3xl mb-6 md:mb-10">Projects</h3>
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
            {projects.map((project) => <ProjectCard project={project} />)}
          </div>
      </section>
    </div>
	</body>
</html>
